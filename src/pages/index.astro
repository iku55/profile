---
import Layout from '../layouts/Layout.astro';
import portfolio from '../data/portfolio.json';
import Header from '../components/Header.astro';
import HeroSection from '../components/HeroSection.astro';

const { profile, navLinks, works, skills, education, articles, links, footer } = portfolio;

let qiitaPosts = [];
try {
  const response = await fetch(`https://qiita.com/api/v2/users/${articles.qiitaUsername}/items?per_page=3`);
  if (response.ok) {
    const data = await response.json();
    qiitaPosts = data.map((item: any) => ({
      title: item.title,
      url: item.url,
      pubDate: new Date(item.created_at).toLocaleDateString('ja-JP'),
      source: 'Qiita',
    }));
  }
} catch (error) {
  console.error("Qiita記事の取得に失敗しました:", error);
}
---

<Layout title={`${profile.name} | Portfolio`}>
  <Header />
  <HeroSection />

  <div id="content-start" class="max-w-4xl mx-auto px-6 py-16 space-y-24 bg-white text-slate-800 dark:bg-slate-950 dark:text-slate-100">
    <section id="works" class="scroll-mt-24">
      <h2 class="text-xl font-bold border-b pb-2 mb-6 dark:border-slate-800">Works</h2>
      
      <div class="relative max-w-2xl mx-auto overflow-hidden rounded-xl border border-slate-200 dark:border-slate-800 shadow-md group bg-slate-950">
        <div id="slider-track" class="flex transition-transform duration-300 ease-in-out">
          
          {works.map((work, index) => (
            <div class="w-full shrink-0 aspect-[16/9] relative flex items-center justify-center bg-gradient-to-br text-slate-500 text-xs" class:list={[work.gradient]}>
              
              {/* 各アプリの背景画像 */}
              {work.bgUrl ? (
                <img src={work.bgUrl} alt={work.title} class="absolute inset-0 w-full h-full object-cover z-0" />
              ) : (
                <span class="relative z-10">No Image</span>
              )}

              {/* テキストコンテンツ情報 */}
              <div class="absolute bottom-0 inset-x-0 bg-slate-900/60 backdrop-blur-sm p-4 border-t border-white/10 text-white flex flex-col gap-0.5 z-10">
                <h3 class="text-sm font-bold">{work.title}</h3>
                <p class="text-xs text-slate-300 line-clamp-1">{work.description}</p>
                <div class="flex justify-end mt-1">
                  <a target="_blank" rel="noopener noreferrer" href={work.url} class="text-[11px] font-semibold text-blue-400 hover:text-blue-300 transition flex items-center gap-0.5">
                    詳しく見る <span>&rarr;</span>
                  </a>
                </div>
              </div>
            </div>
          ))}

        </div>

        <button id="prev-btn" class="absolute left-3 top-[40%] -translate-y-1/2 bg-black/20 hover:bg-black/50 text-white p-2 rounded-full transition-colors z-20" aria-label="Previous slide">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
        </button>
        <button id="next-btn" class="absolute right-3 top-[40%] -translate-y-1/2 bg-black/20 hover:bg-black/50 text-white p-2 rounded-full transition-colors z-20" aria-label="Next slide">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </button>

        <div class="absolute bottom-24 left-1/2 -translate-x-1/2 flex gap-2 z-20">
          {works.map((_, index) => (
            <button class="slider-dot w-2 h-2 rounded-full bg-white transition-all duration-200" data-index={index} aria-label={`Slide ${index + 1}`}></button>
          ))}
        </div>
      </div>
    </section>

    <section id="skills" class="scroll-mt-24">
      <h2 class="text-xl font-bold border-b pb-2 mb-6 dark:border-slate-800">Skills</h2>
      <div class="flex flex-wrap gap-x-6 gap-y-4 text-sm font-semibold text-slate-700 dark:text-slate-300 items-center">
        {skills.map((skill) => (
          <div class="flex items-center gap-2">
            <img src={skill.icon} class="w-5 h-5 object-contain" alt={skill.name} />
            <span>{skill.name}</span>
          </div>
        ))}
      </div>
    </section>

    <section id="education" class="scroll-mt-24">
      <h2 class="text-xl font-bold border-b pb-2 mb-6 dark:border-slate-800">Education</h2>
      <div class="relative border-l-2 border-slate-200 dark:border-slate-800 pl-4 ml-2">
        {education.map((edu) => (
          <div class="mb-4 relative">
            <div class="absolute -left-[21px] top-1.5 w-2.5 h-2.5 rounded-full bg-blue-500"></div>
            <time class="text-xs font-semibold text-slate-400">{edu.period}</time>
            <h3 class="text-base font-bold text-slate-900 dark:text-white">{edu.institution}</h3>
          </div>
        ))}
      </div>
    </section>

    <section id="articles" class="scroll-mt-24">
      <h2 class="text-xl font-bold border-b pb-2 mb-6 dark:border-slate-800">Articles</h2>
      <div class="space-y-4">
        {qiitaPosts.length > 0 ? (
          qiitaPosts.map((post) => (
            <a href={post.url} target="_blank" rel="noopener noreferrer" 
               class="block p-4 bg-slate-50 dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm hover:border-blue-500 dark:hover:border-blue-400 transition-colors duration-200 text-sm">
              <div class="flex items-center justify-between gap-4">
                <div class="flex items-center gap-3">
                  <span class="text-xs font-mono text-slate-400">{post.pubDate}</span>
                  <span class="text-xs font-bold px-2 py-0.5 rounded bg-green-100 text-green-700 dark:bg-green-950 dark:text-green-300">
                    {post.source}
                  </span>
                </div>
              </div>
              <h3 class="text-base font-bold mt-2 text-slate-800 dark:text-slate-100">
                {post.title}
              </h3>
            </a>
          ))
        ) : (
          <p class="text-slate-500 text-sm">記事を取得できませんでした</p>
        )}
      </div>
    </section>

    <section id="links" class="scroll-mt-24">
      <h2 class="text-xl font-bold border-b pb-2 mb-6 dark:border-slate-800">Links</h2>
      
      <div class="space-y-4 text-sm font-semibold">
        {links.map((link) => (
          <div class="flex items-center">
            <a href={link.url} target="_blank" rel="noopener noreferrer" 
               class:list={[
                 "inline-flex items-center gap-3 text-slate-600 dark:text-slate-400 transition-colors duration-200 group",
                 link.color
               ]}>
              
              {/* 各アイコン画像を動的に表示 */}
              {link.icon && (
                <img 
                  src={link.icon} 
                  alt="" 
                  class="w-4 h-4 object-contain" 
                />
              )}

              <span class="font-mono">
                {link.platform} / {link.label}
              </span>
            </a>
          </div>
        ))}
      </div>
    </section>

  </div>

  <footer class="w-full bg-slate-50 dark:bg-slate-900/30 border-t border-slate-100 dark:border-slate-900/60 py-8 text-center text-xs text-slate-400 dark:text-slate-500">
    <p>{footer}</p>
  </footer>

</Layout>

<script>
  const track = document.getElementById('slider-track') as HTMLElement;
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');
  const dots = document.querySelectorAll('.slider-dot');
  
  let currentIndex = 0;
  const slideCount = dots.length;

  function updateSlider(index: number) {
    if (!track || slideCount === 0) return;
    if (index < 0) index = slideCount - 1;
    if (index >= slideCount) index = 0;
    
    currentIndex = index;
    track.style.transform = `translateX(-${currentIndex * 100}%)`;
    
    dots.forEach((dot, i) => {
      if (i === currentIndex) {
        dot.classList.remove('bg-white/40', 'w-2');
        dot.classList.add('bg-white', 'w-5');
      } else {
        dot.classList.remove('bg-white', 'w-5');
        dot.classList.add('bg-white/40', 'w-2');
      }
    });
  }

  prevBtn?.addEventListener('click', () => updateSlider(currentIndex - 1));
  nextBtn?.addEventListener('click', () => updateSlider(currentIndex + 1));

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => updateSlider(i));
  });

  updateSlider(0);
</script>