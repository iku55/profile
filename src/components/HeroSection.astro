---
import portfolio from "../data/portfolio.json";

const { profile } = portfolio;
---

<section
    class="relative h-screen flex flex-col bg-slate-900 text-white overflow-hidden"
>
    <div
        class="absolute inset-y-0 right-0 w-full opacity-20 pointer-events-none z-0"
    >
        {
            profile.heroBgUrl && (
                <img
                    src={profile.heroBgUrl}
                    alt=""
                    class="w-full h-full object-cover"
                />
            )
        }
    </div>

    <div
        class="relative z-10 max-w-4xl w-full mx-auto px-6 mb-2 mt-auto flex flex-col gap-3"
    >
        <div class="flex items-center gap-4">
            <img
                src={profile.avatarUrl}
                alt={profile.name}
                class="w-10 h-10 rounded-full border border-slate-600 shadow-lg"
            />
            <div>
                <h1 class="text-2xl font-bold tracking-tight text-white">
                    {profile.name}
                </h1>
            </div>
        </div>
        <p class="text-lg font-bold text-slate-100 max-w-xl">
            {profile.tagline}
        </p>
        <p class="text-sm text-slate-400 max-w-xl">
            {profile.text}
        </p>
    </div>

    <div class="relative z-10 w-full flex justify-center pb-4">
        <a
            href="#content-start"
            aria-label="Scroll down"
            class="p-1 text-slate-500 hover:text-white transition"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M19 9l-7 7-7-7"></path>
            </svg>
        </a>
    </div>
</section>
